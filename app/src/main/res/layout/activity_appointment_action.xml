<?xml version="1.0" encoding="utf-8"?>
<!-- Accept/Reject decision centered in a soft elevated card -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true"
    tools:context=".AppointmentActionActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvActionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/appointment_action_title"
            android:textAppearance="@style/TextAppearance.Medical.Title"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/appointment_action_subtitle"
            android:textAppearance="@style/TextAppearance.Medical.Subtitle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/Widget.Medical.Card"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPatientName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textAppearance="@style/TextAppearance.Medical.Body"
                tools:text="Name: John Doe" />

            <TextView
                android:id="@+id/tvDoctorName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textAppearance="@style/TextAppearance.Medical.Body"
                tools:text="Doctor: Dr. Smith" />

            <TextView
                android:id="@+id/tvAppointmentDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textAppearance="@style/TextAppearance.Medical.Body"
                tools:text="Appointment Date: 30/05/2026" />

            <TextView
                android:id="@+id/tvDisease"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Medical.Body"
                tools:text="Disease: Chest pain" />

            <Button
                android:id="@+id/btnAccept"
                style="@style/Widget.Medical.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/btn_accept" />

            <Button
                android:id="@+id/btnReject"
                style="@style/Widget.Medical.Button.Reject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/btn_reject" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
