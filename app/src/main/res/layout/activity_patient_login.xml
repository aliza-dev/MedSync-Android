<?xml version="1.0" encoding="utf-8"?>
<!-- Login form centered vertically using NestedScrollView gravity center -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true"
    tools:context=".LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_avatar_circle"
            android:contentDescription="@string/btn_login"
            android:padding="16dp"
            android:src="@drawable/ic_medical_logo" />

        <TextView
            android:id="@+id/tvLoginTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/login_title"
            android:textAppearance="@style/TextAppearance.Medical.Title"
            android:textSize="24sp" />

        <!-- Rounded card wraps inputs for a soft Apple-like form -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/Widget.Medical.Card"
            android:orientation="vertical">

            <EditText
                android:id="@+id/etEmail"
                style="@style/Widget.Medical.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress" />

            <EditText
                android:id="@+id/etPassword"
                style="@style/Widget.Medical.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/hint_password"
                android:inputType="textPassword" />

            <Button
                android:id="@+id/btnLogin"
                style="@style/Widget.Medical.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/btn_login" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
