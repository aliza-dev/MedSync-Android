<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true"
    tools:context=".DoctorProfileActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/bg_avatar_circle"
                android:contentDescription="@string/doctor_profile_title"
                android:padding="20dp"
                android:src="@drawable/ic_medical_logo" />

            <TextView
                android:id="@+id/tvProfileTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/doctor_profile_title"
                android:textAppearance="@style/TextAppearance.Medical.Subtitle" />

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.Medical.Title"
                android:textSize="22sp"
                tools:text="Dr. Jane Smith" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Medical.Card"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvEmailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_email"
                android:textAppearance="@style/TextAppearance.Medical.Label" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:textAppearance="@style/TextAppearance.Medical.Body"
                tools:text="jane@example.com" />

            <TextView
                android:id="@+id/tvSpecializationLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_specialization"
                android:textAppearance="@style/TextAppearance.Medical.Label" />

            <TextView
                android:id="@+id/tvNameLabel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvSpecialization"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.Medical.Body"
                tools:text="Cardiologist" />

        </LinearLayout>

        <Button
            android:id="@+id/btnViewPendingAppointments"
            style="@style/Widget.Medical.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/btn_view_pending_appointments" />

        <Button
            android:id="@+id/btnTodaysAppointments"
            style="@style/Widget.Medical.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/btn_todays_appointments" />

        <Button
            android:id="@+id/btnViewPatientHistory"
            style="@style/Widget.Medical.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/btn_view_patient_history" />

        <Button
            android:id="@+id/btnLogout"
            style="@style/Widget.Medical.Button.Reject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:text="@string/btn_logout" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
