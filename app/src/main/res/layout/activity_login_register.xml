<?xml version="1.0" encoding="utf-8"?>
<!-- Landing screen: vertical centering via NestedScrollView fillViewport + gravity center -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true"
    tools:context=".LoginRegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:background="@drawable/bg_avatar_circle"
            android:contentDescription="@string/app_name"
            android:padding="18dp"
            android:src="@drawable/ic_medical_logo" />

        <TextView
            android:id="@+id/tvAuthTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/login_register_title"
            android:textAppearance="@style/TextAppearance.Medical.Title"
            android:textSize="26sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/login_register_subtitle"
            android:textAppearance="@style/TextAppearance.Medical.Subtitle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            style="@style/Widget.Medical.Card"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnLogin"
                style="@style/Widget.Medical.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_login" />

            <Button
                android:id="@+id/btnGoToRegister"
                style="@style/Widget.Medical.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/btn_register_patient" />

            <Button
                android:id="@+id/btnGoToDoctorRegister"
                style="@style/Widget.Medical.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/btn_register_doctor" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
