<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true"
    tools:context=".BookAppointmentActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_avatar_circle"
            android:contentDescription="@string/book_appointment_title"
            android:padding="14dp"
            android:src="@drawable/ic_medical_logo" />

        <TextView
            android:id="@+id/tvBookTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/book_appointment_title"
            android:textAppearance="@style/TextAppearance.Medical.Title"
            android:textSize="24sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/Widget.Medical.Card"
            android:orientation="vertical">

            <EditText
                android:id="@+id/etDoctorName"
                style="@style/Widget.Medical.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_doctor_name"
                android:inputType="textPersonName" />

            <EditText
                android:id="@+id/etDate"
                style="@style/Widget.Medical.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/hint_date"
                android:inputType="date" />

            <EditText
                android:id="@+id/etDisease"
                style="@style/Widget.Medical.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/hint_disease"
                android:inputType="textMultiLine"
                android:minLines="2" />

            <Button
                android:id="@+id/btnSubmitRequest"
                style="@style/Widget.Medical.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/btn_submit_request" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
